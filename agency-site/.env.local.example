# ============================================================
# SUPABASE (récupère ces clés dans Project Settings → API)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
# Sert uniquement côté serveur (API routes). NE JAMAIS exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=ey...

# ============================================================
# SITE MARKETING PUBLIC
# ============================================================
# WhatsApp de contact (format international SANS le +)
NEXT_PUBLIC_WHATSAPP_NUMBER=237600000000

# ============================================================
# MOTEUR DE PROSPECTION (/admin)
# ============================================================
# Apify — scraping Google Maps (https://console.apify.com/account/integrations)
APIFY_TOKEN=apify_api_xxx
# (Optionnel) acteur Apify. Par défaut : scraping enrichi avec emails + réseaux.
# Pour un scraping basique/rapide : compass~crawler-google-places
APIFY_ACTOR=lukaskrivka~google-maps-with-contact-details

# Anthropic — audit IA (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
# (Optionnel) modèle Claude utilisé pour l'audit
ANTHROPIC_MODEL=claude-sonnet-4-6

# Protection du dashboard /admin (Basic Auth).
# Si ADMIN_PASSWORD est vide → accès libre (pratique en local).
ADMIN_USER=admin
ADMIN_PASSWORD=change-moi-en-prod
